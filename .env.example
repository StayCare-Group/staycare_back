# ─── Database (required) ──────────────────────────────────────────────────────
DATABASE_URL="mongodb://localhost:27017/staycare"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="development"

# Frontend origin allowed by CORS (must match the running frontend URL)
CLIENT_URL="http://localhost:5173"

# ─── JWT (required) ───────────────────────────────────────────────────────────
# Use long, randomly generated strings — never reuse across environments
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Token lifetimes in seconds
# 900 = 15 minutes (access), 604800 = 7 days (refresh)
ACCESS_TOKEN_EXPIRES=900
REFRESH_TOKEN_EXPIRES=604800

# ─── SMTP – email (optional) ──────────────────────────────────────────────────
# Required for invitation emails and password-reset emails.
# If SMTP_USER and SMTP_PASS are not set, email sending is silently skipped.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="StayCare <your-email@gmail.com>"